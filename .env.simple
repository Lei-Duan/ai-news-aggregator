# AI News Aggregator - Simple Configuration (No Reddit API needed)

# Twitter API v2 - Required
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# GitHub Token - Required
GITHUB_TOKEN=your_github_token_here

# Anthropic API - Optional (for better summaries)
# If not provided, will use basic keyword extraction
ANTHROPIC_API_KEY=optional_your_anthropic_api_key_here

# Notion Integration - Required
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Reddit - NOT NEEDED! Using RSS instead
# REDDIT_CLIENT_ID=not_needed
# REDDIT_CLIENT_SECRET=not_needed

# Scheduler Settings
SCHEDULE_TIME=09:00
TIMEZONE=US/Pacific

# Content Filtering
MIN_QUALITY_SCORE=0.5
MAX_ARTICLES_PER_SOURCE=10
SUMMARY_MAX_LENGTH=200

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/aggregator.log